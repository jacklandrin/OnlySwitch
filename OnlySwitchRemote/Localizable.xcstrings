    "OnlySwitch couldn’t load saved Macs. Your current screen was kept." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikaci OnlySwitch se nepodařilo načíst uložené počítače Mac. Aktuální obrazovka byla zachována."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch konnte die gespeicherten Macs nicht laden. Ihr aktueller Bildschirm wurde beibehalten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch no pudo cargar los Mac guardados. Se mantuvo tu pantalla actual."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hindi na-load ng OnlySwitch ang mga naka-save na Mac. Pinanatili ang iyong kasalukuyang screen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch n'a pas pu charger les Mac enregistrés. Votre écran actuel a été conservé."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch nije mogao učitati spremljene Macove. Trenutni zaslon je zadržan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch non è riuscito a caricare i Mac salvati. La schermata corrente è stata mantenuta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch で保存された Mac を読み込めませんでした。現在の画面は保持されました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch에서 저장된 Mac을 로드할 수 없습니다. 현재 화면이 유지되었습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch kon de opgeslagen Mac-apparaten niet laden. Je huidige scherm is behouden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikacja OnlySwitch nie mogła załadować zapisanych komputerów Mac. Aktualny ekran został zachowany."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O OnlySwitch não pôde carregar os Macs salvos. Sua tela atual foi mantida."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Приложению OnlySwitch не удалось загрузить сохранённые Mac. Текущий экран сохранён."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch nemohol načítať uložené Macy. Vaša aktuálna obrazovka bola zachovaná."
          }
        },
        "so" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch waxay ku guuldarreystay inay soo dejiso Mac-yadii la keydiyey. Shaashaddaada hadda jirta waa la ilaaliyey."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch kaydedilmiş Mac'leri yükleyemedi. Mevcut ekranınız korundu."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch не вдалося завантажити збережені Mac. Поточний екран залишено."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch 无法加载已保存的 Mac。当前屏幕已保留。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch 無法載入已儲存的 Mac。您的目前畫面已保留。"
          }
        }
      }
    },
    "OnlySwitch couldn’t remove all local data for this Mac. Retry to finish forgetting it." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikaci OnlySwitch se nepodařilo odstranit všechna lokální data pro tento Mac. Zkuste to znovu, abyste dokončili jeho odebrání."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch konnte nicht alle lokalen Daten für diesen Mac entfernen. Versuchen Sie es erneut, um das Vergessen abzuschließen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch no pudo eliminar todos los datos locales de este Mac. Reintenta para terminar de olvidarlo."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hindi maalis ng OnlySwitch ang lahat ng lokal na data para sa Mac na ito. Subukang muli para tuluyang makalimutan ito."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch n'a pas pu supprimer toutes les données locales pour ce Mac. Réessayez pour terminer l'oubli."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch nije uspio ukloniti sve lokalne podatke za ovaj Mac. Pokušajte ponovno da biste dovršili njegovo zaboravljanje."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch non è riuscito a rimuovere tutti i dati locali per questo Mac. Riprova per completare la rimozione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch でこの Mac のすべてのローカルデータを削除できませんでした。削除を完了するには、もう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch에서 이 Mac의 모든 로컬 데이터를 제거하지 못했습니다. 지우기를 완료하려면 다시 시도하세요."
