    "Enable iOS Remote Access and start pairing in OnlySwitch on your Mac." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Povolte vzdálený přístup pro iOS a zahajte párování v aplikaci OnlySwitch na vašem Macu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivieren Sie den iOS-Fernzugriff und starten Sie die Kopplung in OnlySwitch auf Ihrem Mac."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activa el acceso remoto para iOS e inicia el emparejamiento en OnlySwitch en tu Mac."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I-enable ang iOS Remote Access at magsimula ng pairing sa OnlySwitch sa iyong Mac."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activez l'accès à distance sur iOS et lancez l'appairage dans OnlySwitch sur votre Mac."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omogućite daljinski pristup za iOS i započnite uparivanje u OnlySwitchu na vašem Macu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abilita l'accesso remoto per iOS e avvia l'accoppiamento in OnlySwitch sul tuo Mac."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mac の OnlySwitch で iOS リモートアクセスを有効にして、ペアリングを開始してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mac의 OnlySwitch에서 iOS 원격 액세스를 활성화하고 페어링을 시작하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schakel iOS-externe toegang in en begin met koppelen in OnlySwitch op je Mac."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Włącz zdalny dostęp z iOS i rozpocznij parowanie w aplikacji OnlySwitch na komputerze Mac."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ative o Acesso Remoto no iOS e inicie o pareamento no OnlySwitch no seu Mac."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Включите удалённый доступ для iOS и начните сопряжение в OnlySwitch на вашем Mac."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Povoliť vzdialený prístup iOS a začať párovanie v OnlySwitch na vašom Macu."
          }
        },
        "so" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kordhi helitaanka fog ee iOS oo bilaab isku-xiridda (pairing) ku jirta OnlySwitch ee Mac-gaaga."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS Uzaktan Erişimi etkinleştirin ve Mac'inizdeki OnlySwitch'te eşleşmeyi başlatın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Увімкніть віддалений доступ для iOS та почніть спарювання в OnlySwitch на вашому Mac."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 Mac 上的 OnlySwitch 中启用 iOS 远程访问并开始配对。"
          }
