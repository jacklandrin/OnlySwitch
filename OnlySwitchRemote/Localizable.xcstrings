          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Переконайтеся, що в OnlySwitch на вашому Mac активні віддалений доступ і спарювання."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
