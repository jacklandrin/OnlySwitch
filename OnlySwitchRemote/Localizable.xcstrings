    "The dashboard layout wasn’t saved. Your latest choices are still available to retry." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rozložení přehledu nebylo uloženo. Vaše poslední volby jsou stále k dispozici pro opakování."
