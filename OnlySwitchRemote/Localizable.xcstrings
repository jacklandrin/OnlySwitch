          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зачекайте хвилину, почніть нову сесію спарювання на Mac та спробуйте ще раз."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请稍候，在 Mac 上启动新的配对会话，然后重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "請稍候，於 Mac 上啟動新的配對會話後再試一次。"
          }
        }
      }
    },
