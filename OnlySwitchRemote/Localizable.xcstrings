          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Убедитесь, что удалённый доступ и сопряжение активны в OnlySwitch на вашем Mac."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uistite sa, že v OnlySwitch na vašom Macu sú aktivované vzdialený prístup a párovanie."
          }
        },
        "so" : {
          "stringUnit" : {
            "state" : "translated",
