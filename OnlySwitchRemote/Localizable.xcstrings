    "Forgetting removes this Mac’s credential, cached controls, statuses, and dashboard layout from this device." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odebráním se z tohoto zařízení odstraní pověření, mezipaměť ovládacích prvků, stavy a rozložení přehledu pro tento Mac."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Vergessen werden die Zugangsdaten dieses Macs, zwischengespeicherte Steuerelemente, Status und das Dashboard-Layout von diesem Gerät entfernt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al olvidar este Mac, se eliminan de este dispositivo sus credenciales, los controles y estados almacenados en caché y la disposición del panel."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kapag kinalimutan ang Mac na ito, aalisin sa device na ito ang kredensyal nito, mga naka-cache na kontrol at status, at layout ng dashboard."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'oubli supprime les identifiants de ce Mac, les contrôles mis en cache, les statuts et la disposition du tableau de bord de cet appareil."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaboravljanjem s ovog uređaja uklanjaju se vjerodajnice, predmemorirane kontrole, statusi i raspored nadzorne ploče za ovaj Mac."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La rimozione elimina le credenziali di questo Mac, i controlli memorizzati nella cache, gli stati e il layout della dashboard da questo dispositivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "削除すると、このデバイスからこの Mac の認証情報、キャッシュされたコントロール、ステータス、およびダッシュボードレイアウトが削除されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mac을 지우면 이 기기에서 해당 Mac의 자격 증명, 캐시된 제어 항목, 상태 및 대시보드 레이아웃이 제거됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vergeten verwijdert de inloggegevens, de opgeslagen besturingselementen, statussen en het dashboardindeling van deze Mac van dit apparaat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usunięcie powoduje usunięcie poświadczenia tego komputera Mac, pamięci podręcznej elementów sterujących, stanów i układu pulpitu z tego urządzenia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ao esquecer, são removidas as credenciais deste Mac, os controles em cache, os status e o layout do painel deste dispositivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "При удалении с этого устройства будут удалены учётные данные этого Mac, кэшированные элементы управления, статусы и макет панели управления."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zabudnutím tohto Macu sa zo zariadenia odstránia jeho prihlasovacie údaje, ovládacie prvky a stavy vo vyrovnávacej pamäti aj rozloženie dashboardu."
          }
        },
        "so" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iloowista waxay ka saaraysaa shahaadada Mac-gan, xakamaynta la keydiyey, xaaladaha, iyo qaab-dhismeedka Dashboard-ka ee qalabkan."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unutmak işlemi, bu cihazdan bu Mac'in kimlik bilgilerini, önbelleğe alınmış kontrollerini, durumlarını ve kontrol paneli düzenini kaldırır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Після забуття з цього пристрою буде видалено облікові дані, кешовані елементи керування, статуси та макет панелі приладів для цього Mac."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“忘记”操作将从本设备移除该 Mac 的凭证、缓存的控制项、状态及仪表板布局。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "忘記操作將從此裝置移除該 Mac 的憑證、快取控制項、狀態及儀表板佈局。"
          }
        }
      }
    },
