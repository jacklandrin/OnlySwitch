        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch kon alle lokale gegevens voor deze Mac niet verwijderen. Probeer het opnieuw om het vergeten te voltooien."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikacja OnlySwitch nie mogła usunąć wszystkich danych lokalnych dla tego komputera Mac. Spróbuj ponownie, aby zakończyć jego usuwanie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O OnlySwitch não pôde remover todos os dados locais deste Mac. Tente novamente para concluir o esquecimento."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Приложению OnlySwitch не удалось удалить все локальные данные для этого Mac. Повторите попытку, чтобы завершить удаление."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch nemohol odstrániť všetky miestne dáta tohto Macu. Skúste to znova, aby ste dokončili jeho zabudnutie."
          }
        },
        "so" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch waxay ku guuldarreystay inay ka saarto dhammaan xogta deegaanka ee Mac-gan. Isku day mar kale si aad u dhammaystirto ilowista."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
