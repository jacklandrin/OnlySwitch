    "Wait a moment, start a new pairing session on the Mac, and try again." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Počkejte chvíli, zahajte nové párování na Macu a zkuste to znovu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warten Sie einen Moment, starten Sie eine neue Kopplungssitzung auf dem Mac und versuchen Sie es erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espera un momento, inicia una nueva sesión de emparejamiento en el Mac e inténtalo de nuevo."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maghintay ng sandali, magsimula ng bagong sesyon ng pairing sa Mac, at subukan muli."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Attendez un instant, lancez une nouvelle session d'appairage sur le Mac et réessayez."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pričekajte trenutak, započnite novu sesiju uparivanja na Macu i pokušajte ponovno."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Attendi un momento, avvia una nuova sessione di accoppiamento sul Mac e riprova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "しばらく待ってから、Mac で新しいペアリングセッションを開始し、もう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "잠시 기다린 후 Mac에서 새 페어링 세션을 시작하고 다시 시도하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wacht even, start een nieuwe koppelingssessie op de Mac en probeer het opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poczekaj chwilę, rozpocznij nową sesję parowania na komputerze Mac i spróbuj ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aguarde um momento, inicie uma nova sessão de pareamento no Mac e tente novamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подождите немного, начните новый сеанс сопряжения на Mac и повторите попытку."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Počkajte chvíľu, začnite novú reláciu párovania na Macu a skúste to znova."
          }
        },
        "so" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sug muddo yar, bilaab fursad cusub oo isku-xirid ku jirta Mac-ga, kadibna isku day mar kale."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
