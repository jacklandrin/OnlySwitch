          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Upewnij się, że zdalny dostęp i parowanie są aktywne w aplikacji OnlySwitch na komputerze Mac."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
