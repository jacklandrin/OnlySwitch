          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch не вдалося завантажити збережені Mac. Поточний екран залишено."
          }
        }
      }
    },
    "OnlySwitch couldn’t remove all local data for this Mac. Retry to finish forgetting it." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikaci OnlySwitch se nepodařilo odstranit všechna lokální data pro tento Mac. Zkuste to znovu, abyste dokončili jeho odebrání."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch konnte nicht alle lokalen Daten für diesen Mac entfernen. Versuchen Sie es erneut, um das Vergessen abzuschließen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch no pudo eliminar todos los datos locales de este Mac. Reintenta para terminar de olvidarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch n'a pas pu supprimer toutes les données locales pour ce Mac. Réessayez pour terminer l'oubli."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OnlySwitch nije uspio ukloniti sve lokalne podatke za ovaj Mac. Pokušajte ponovno da biste dovršili njegovo zaboravljanje."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
